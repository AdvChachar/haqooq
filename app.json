{
  "expo": {
    "name": "Haqooq",
    "slug": "haqooq",
    "version": "1.0.0",
    "description": "Haqooq is a free AI-powered legal aid app for Pakistani citizens. Get simple answers about Pakistani laws — FIR filing, bail, family law, property rights, labor law, and more. Available in Urdu and English.",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "privacy": "public",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#071440"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.haqooq.legalaid",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#071440"
      },
      "package": "com.haqooq.legalaid",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "scheme": "haqooq",
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c1863dee-1e49-4df6-be16-9d4581cf2506"
      }
    },
    "owner": "mr.chachar"
  }
}